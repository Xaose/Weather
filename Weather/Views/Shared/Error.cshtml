@using System.Globalization
@model ErrorViewModel

@functions {
    public static string T(string en, string ru, string be)
    {
        var language = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        return language switch
        {
            "ru" => ru,
            "be" => be,
            _ => en
        };
    }
}

@{
    ViewData["Title"] = T("Error", "Ошибка", "Памылка");
}

<h1 class="text-danger">@T("Error.", "Ошибка.", "Памылка.")</h1>
<h2 class="text-danger">@T("An error occurred while processing your request.", "При обработке вашего запроса произошла ошибка.", "Падчас апрацоўкі вашага запыту адбылася памылка.")</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>@T("Request ID:", "ID запроса:", "ID запыту:")</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>@T("Development Mode", "Режим разработки", "Рэжым распрацоўкі")</h3>
<p>
    @T("Switching to the Development environment displays detailed error information.", "Переключение в среду Development покажет подробную информацию об ошибке.", "Пераключэнне ў асяроддзе Development пакажа падрабязную інфармацыю пра памылку.")
</p>
<p>
    @if (CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ru")
    {
        <strong>Режим Development не должен быть включен на рабочем сервере.</strong>
        <text> Для локальной отладки задайте ASPNETCORE_ENVIRONMENT=Development и перезапустите приложение.</text>
    }
    else if (CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "be")
    {
        <strong>Рэжым Development не павінен быць уключаны ў прадакшн-асяроддзі.</strong>
        <text> Для лакальнай адладкі задайце ASPNETCORE_ENVIRONMENT=Development і перазапусціце прыкладанне.</text>
    }
    else
    {
        <strong>Development mode should not be enabled in production.</strong>
        <text> For local debugging, set ASPNETCORE_ENVIRONMENT=Development and restart the app.</text>
    }
</p>